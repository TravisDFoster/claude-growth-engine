# Credentials — never commit
.env

# Branding assets — 6GB, too large for GitHub
marketing/design/branding-assets/

# HubSpot contact data — PII
hubspot/data/audit-logs/

# Personal-assistant state — projects, weekly calendar, meeting notes (internal ops)
personal-assistant/projects/
personal-assistant/calendar/
personal-assistant/meetings/

# Active sales pipeline + named prospect work — PII / competitive
sales/sales-reporting/reports/

# sales/presentations/: process-only folder. Ignore stray local files; keep the system files.
sales/presentations/*
!sales/presentations/CLAUDE.md
!sales/presentations/presentation-process.md

# sales/prospects/: named prospect work (decks, brand kits, roadmaps) — local-only, PII / competitive.
# Allowlist only the convention router; every <prospect>/ folder stays local.
sales/prospects/*
!sales/prospects/CLAUDE.md

# HubSpot CRM audit reports — portal-level stats + contact-level findings
hubspot/reports/

# SEO program — strategy, keyword maps, briefs, audits, reports
marketing/seo/

# Mac noise
.DS_Store
**/.DS_Store

# Python
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Derived report data — regenerated by scripts; the .html deliverable + scripts are tracked
sales/sales-reporting/tmp/

# Deal Report — per-deal health drilldown. tmp/ holds raw + cleaned email bodies (PII)
# and reports/ holds deal-level data; both local-only. Scripts + docs are tracked.
sales/deal-report/tmp/
sales/deal-report/reports/

# Helpdesk scrape cache — regenerated by shared/features/scripts/
shared/features/cache/
